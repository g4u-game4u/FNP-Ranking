# Supabase Configuration
VITE_SUPABASE_URL=https://fnp.centralsupernova.com.br
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Development Configuration
VITE_APP_TITLE=Chicken Race Ranking
VITE_API_POLLING_INTERVAL=30000

# Google Sheets API Configuration (Client-side - optional, kept for compatibility)
VITE_GOOGLE_SHEETS_CLIENT_ID=your_google_client_id_here
VITE_GOOGLE_SHEETS_CLIENT_SECRET=your_google_client_secret_here
VITE_GOOGLE_SHEETS_API_KEY=your_google_api_key_here
VITE_GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here

# Google Sheets API Configuration (Server-side - required for /api/daily-code endpoint)
# These are used by the serverless function and NOT exposed to the browser
GOOGLE_SHEETS_API_KEY=your_google_api_key_here
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here
